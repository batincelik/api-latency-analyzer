{
  "name": "@ala/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:int": "vitest run --config vitest.int.config.ts"
  },
  "dependencies": {
    "@ala/config": "workspace:*",
    "@ala/db": "workspace:*",
    "@ala/logger": "workspace:*",
    "@ala/shared": "workspace:*",
    "@ala/types": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
