{
  "name": "apilatencyanalyzer",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm run --parallel --filter @ala/api --filter @ala/worker --filter @ala/web dev",
    "dev:api": "pnpm --filter @ala/api dev",
    "dev:worker": "pnpm --filter @ala/worker dev",
    "dev:web": "pnpm --filter @ala/web dev",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:e2e": "pnpm --filter @ala/web test:e2e",
    "db:generate": "pnpm --filter @ala/db generate",
    "db:migrate": "pnpm --filter @ala/db migrate:dev",
    "db:push": "pnpm --filter @ala/db push",
    "db:seed": "pnpm --filter @ala/db seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.21.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
